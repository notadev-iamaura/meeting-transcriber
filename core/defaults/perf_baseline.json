{
  "_comment": "파이프라인 단계별 보수적 기본 처리 속도(rate = elapsed_seconds / input_unit). 사용자 기기에서 3건 이상 처리되면 EMA 값으로 대체된다. 배포자는 새 모델 추가 시 여기에 한 줄 추가.",
  "version": 1,
  "rates": {
    "convert": {
      "_unit": "seconds_per_MB",
      "_note": "ffmpeg 변환 — 입력 MB당 대략 0.3초, 보수적으로 0.5초",
      "default": 0.5
    },
    "transcribe": {
      "_unit": "seconds_per_audio_second",
      "_note": "mlx-whisper RTF. 모델별 값이 registry에 있지만 보수적으로 2배 적용",
      "default": 0.6,
      "by_model": {
        "komixv2": 0.15,
        "seastar-medium-4bit": 0.12,
        "ghost613-turbo-4bit": 0.12
      }
    },
    "diarize": {
      "_unit": "seconds_per_audio_second",
      "_note": "pyannote CPU — 오디오 1초당 약 0.15초",
      "default": 0.25
    },
    "merge": {
      "_unit": "seconds_per_audio_second",
      "_note": "순수 CPU 매칭 — 매우 빠름",
      "default": 0.002
    },
    "correct": {
      "_unit": "seconds_per_utterance",
      "_note": "LLM 교정 — 발화 1개당 약 0.4~1.2초 (모델/배치에 따라)",
      "default": 1.0
    },
    "summarize": {
      "_unit": "seconds_per_utterance",
      "_note": "LLM 요약 — 전체 발화 기반 1회 생성",
      "default": 0.3
    }
  },
  "load_overhead_seconds": {
    "_note": "첫 단계 실행 시 모델 로드 오버헤드 (초)",
    "transcribe": 8.0,
    "diarize": 6.0,
    "correct": 12.0,
    "summarize": 2.0
  },
