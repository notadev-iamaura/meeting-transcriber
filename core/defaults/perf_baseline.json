    "M1 Ultra": 1.3,
    "M2": 1.18,
    "M2 Pro": 1.35,
    "M2 Max": 1.4,
    "M2 Ultra": 1.55,
    "M3": 1.35,
    "M3 Pro": 1.5,
    "M3 Max": 1.6,
    "M4": 1.55,
    "M4 Pro": 1.75,
    "M4 Max": 1.9,
    "unknown": 1.0
  }
